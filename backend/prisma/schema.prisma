generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  passwordHash        String?
  googleId            String?       @unique
  phone               String?
  avatarUrl           String?
  plan                UserPlan      @default(free)
  status              UserStatus    @default(active)
  emailVerified       Boolean       @default(false)
  unsubscribeToken    String?       @unique @default(cuid())
  emailPreferences    Json          @default("{\"rsvpNotifications\": true, \"weeklyDigest\": false, \"marketing\": true}")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  lastLoginAt         DateTime?

  invites       Invite[]
  purchases     UserTemplate[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]
  collaborations InviteCollaborator[] @relation("InviteCollaboratorUser")
  accessRequests InviteAccessRequest[] @relation("InviteAccessRequestRequester")
  reviewedAccessRequests InviteAccessRequest[] @relation("InviteAccessRequestDecider")
}

enum UserPlan {
  free
  premium
}

enum UserStatus {
  active
  suspended
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AdminUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         AdminRole  @default(support)
  createdAt    DateTime   @default(now())
  lastLoginAt  DateTime?

  notes         AdminNote[]
  announcements Announcement[]
  auditLogs     AuditLog[]
}

enum AdminRole {
  admin
  support
}

model Template {
  slug             String         @id
  name             String
  category         EventCategory
  tags             String[]
  isPremium        Boolean        @default(false)
  price            Int            @default(0)
  priceUsd         Int            @default(0)
  priceEur         Int            @default(0)
  isVisible        Boolean        @default(true)
  isFeatured       Boolean        @default(false)
  sortOrder        Int            @default(0)
  purchaseCount    Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  purchases  UserTemplate[]
  invites    Invite[]
}

model UserTemplate {
  id            String    @id @default(cuid())
  userId        String
  templateSlug  String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template  @relation(fields: [templateSlug], references: [slug])
  purchasedAt   DateTime  @default(now())
  transactionId String?

  @@unique([userId, templateSlug])
}

model Invite {
  id               String        @id @default(cuid())
  userId           String
  templateSlug     String
  templateCategory EventCategory
  slug             String        @unique
  status           InviteStatus  @default(draft)
  data             Json          @default("{}")
  viewCount        Int           @default(0)
  eventDate        DateTime?
  expiryDate       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateSlug], references: [slug])
  rsvps    Rsvp[]
  notes    AdminNote[]
  guests   InviteGuest[]
  broadcasts InviteBroadcast[]
  collaborators InviteCollaborator[]
  accessRequests InviteAccessRequest[]

  @@index([userId])
  @@index([status])
  @@index([templateSlug])
}

enum InviteStatus {
  draft
  published
  expired
  taken_down
}

model Rsvp {
  id          String       @id @default(cuid())
  inviteId    String
  guestId     String?
  invite      Invite       @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  guest       InviteGuest? @relation(fields: [guestId], references: [id], onDelete: SetNull)
  name        String
  email       String?
  response    RsvpResponse
  guestCount  Int          @default(1)
  message     String?
  adultCount  Int?
  childCount  Int?
  mealChoice  String?
  dietaryRestrictions String?
  customAnswers Json?
  stayNeeded  Boolean?
  roomRequirement String?
  transportNeeded Boolean?
  transportMode String?
  language    String?
  submittedAt DateTime     @default(now())
  ipAddress   String?

  @@index([inviteId])
  @@index([email])
  @@index([guestId])
}

enum RsvpResponse {
  yes
  no
  maybe
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  templateSlug      String
  amount            Int
  currency          String            @default("USD")
  status            TransactionStatus @default(pending)
  razorpayOrderId   String?           @unique
  razorpayPaymentId String?
  promoCode         String?
  discountAmount    Int               @default(0)
  refundedAt        DateTime?
  refundReason      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([createdAt])
}

enum TransactionStatus {
  pending
  success
  failed
  refunded
}

model Category {
  id           String        @id @default(cuid())
  slug         EventCategory @unique
  name         String
  emoji        String
  displayOrder Int           @default(0)
  isVisible    Boolean       @default(true)
}

model PromoCode {
  id            String        @id @default(cuid())
  code          String        @unique
  discountType  DiscountType
  discountValue Int
  isActive      Boolean       @default(true)
  appliesTo     String        @default("all")
  usageLimit    Int?
  usageCount    Int           @default(0)
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
}

enum DiscountType {
  percentage
  flat
}

model Announcement {
  id             String    @id @default(cuid())
  title          String
  content        String
  sentTo         String
  sentByAdminId  String
  sentBy         AdminUser @relation(fields: [sentByAdminId], references: [id])
  sentAt         DateTime  @default(now())
  recipientCount Int       @default(0)
}

model AdminNote {
  id          String    @id @default(cuid())
  entityId    String
  entityType  String
  note        String
  createdById String
  createdBy   AdminUser @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  invite      Invite?   @relation(fields: [entityId], references: [id])

  @@index([entityId, entityType])
}

model AuditLog {
  id         String    @id @default(cuid())
  adminId    String
  admin      AdminUser @relation(fields: [adminId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime  @default(now())

  @@index([adminId])
  @@index([entityId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum EventCategory {
  wedding
  engagement
  birthday
  baby_shower
  corporate
  anniversary
}

enum GuestInvitationStatus {
  invited
  confirmed
  waitlisted
  cancelled
}

enum CollaboratorStatus {
  pending
  active
  revoked
}

enum AccessRequestStatus {
  pending
  approved
  rejected
}

enum BroadcastType {
  venue_change
  timing_update
  rsvp_reminder
  dress_code_reminder
  weather_advisory
  parking_update
  photos_uploaded
  post_event_thank_you
  custom
}

enum BroadcastStatus {
  draft
  sent
  partial
}

enum BroadcastRecipientStatus {
  pending
  sent
  opened
  bounced
}

model InviteGuest {
  id                  String                 @id @default(cuid())
  inviteId            String
  token               String                 @unique @default(cuid())
  name                String
  email               String?
  phone               String?
  household           String?
  audienceSegment     String                 @default("general")
  tags                String[]               @default([])
  language            String                 @default("en")
  invitationStatus    GuestInvitationStatus  @default(invited)
  response            RsvpResponse?
  guestCount          Int                    @default(1)
  adultCount          Int?
  childCount          Int?
  message             String?
  mealChoice          String?
  dietaryRestrictions String?
  customAnswers       Json?
  stayNeeded          Boolean                @default(false)
  lodgingStatus       String?
  hotelName           String?
  roomType            String?
  roomCount           Int                    @default(0)
  checkInDate         DateTime?
  checkOutDate        DateTime?
  shuttleRequired     Boolean                @default(false)
  transportMode       String?
  arrivalDetails      String?
  departureDetails    String?
  parkingRequired     Boolean                @default(false)
  supportNotes        String?
  inviteSentAt        DateTime?
  lastBroadcastAt     DateTime?
  rsvpSubmittedAt     DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  invite              Invite                 @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  rsvps               Rsvp[]
  broadcastRecipients BroadcastRecipient[]

  @@index([inviteId])
  @@index([email])
  @@index([response])
  @@index([audienceSegment])
}

model InviteCollaborator {
  id              String             @id @default(cuid())
  inviteId         String
  userId          String?
  email           String
  name            String?
  roleLabel       String             @default("collaborator")
  permissions     String[]
  status          CollaboratorStatus @default(pending)
  invitedByUserId String
  inviteToken     String             @unique @default(cuid())
  invitedAt       DateTime           @default(now())
  joinedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  invite          Invite             @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user            User?              @relation("InviteCollaboratorUser", fields: [userId], references: [id], onDelete: SetNull)
  accessRequests  InviteAccessRequest[]

  @@unique([inviteId, email])
  @@index([inviteId])
  @@index([email])
}

model InviteAccessRequest {
  id                      String              @id @default(cuid())
  inviteId                String
  requesterUserId         String
  requesterCollaboratorId String
  requestedPermissions    String[]
  status                  AccessRequestStatus @default(pending)
  decidedByUserId         String?
  requestedAt             DateTime            @default(now())
  decidedAt               DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  invite                 Invite             @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  requester             User               @relation("InviteAccessRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  requesterCollaborator InviteCollaborator @relation(fields: [requesterCollaboratorId], references: [id], onDelete: Cascade)
  decider               User?              @relation("InviteAccessRequestDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([inviteId])
  @@index([requesterUserId])
  @@index([requesterCollaboratorId])
  @@index([status])
}

model InviteBroadcast {
  id              String          @id @default(cuid())
  inviteId         String
  type            BroadcastType
  title           String
  subject         String?
  message         String
  language        String          @default("en")
  audience        Json
  status          BroadcastStatus @default(draft)
  sentAt          DateTime?
  createdByUserId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  invite          Invite          @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  recipients      BroadcastRecipient[]

  @@index([inviteId])
  @@index([sentAt])
}

model BroadcastRecipient {
  id           String                   @id @default(cuid())
  broadcastId  String
  guestId      String?
  email        String
  name         String?
  language     String                   @default("en")
  status       BroadcastRecipientStatus @default(pending)
  openToken    String                   @unique @default(cuid())
  sentAt       DateTime?
  openedAt     DateTime?
  bouncedAt    DateTime?
  errorMessage String?
  inviteUrl    String?
  createdAt    DateTime                 @default(now())

  broadcast    InviteBroadcast          @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  guest        InviteGuest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([broadcastId])
  @@index([guestId])
  @@index([status])
}
