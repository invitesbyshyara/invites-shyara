# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:8080
ADMIN_PORTAL_URL=http://localhost:8080
CUSTOMER_ACQUISITION_LOCK_ENABLED=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shyara_invite

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=8h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (email)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@invite.shyara.co.in
